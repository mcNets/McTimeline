<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Light theme Colors -->
	<Color x:Key="McTimelineAccentColor">#0078D4</Color>
	<Color x:Key="McTimelineBackgroundColor">#FFFFFF</Color>
	<Color x:Key="McTimelineForegroundColor">#000000</Color>
	<Color x:Key="McTimelineGridLineColor">#E0E0E0</Color>
	<Color x:Key="McTimelineLegendBackgroundColor">#F5F5F5</Color>
	<Color x:Key="McTimelineMinimapBackgroundColor">#FAFAFA</Color>
	<Color x:Key="McTimelineHoverColor">#E5F3FF</Color>
	<Color x:Key="McTimelineSelectionColor">#CCE8FF</Color>

	<!-- Brushes -->
	<SolidColorBrush x:Key="McTimelineAccentBrush"
					 Color="{StaticResource McTimelineAccentColor}" />
	<SolidColorBrush x:Key="McTimelineBackgroundBrush"
					 Color="{StaticResource McTimelineBackgroundColor}" />
	<SolidColorBrush x:Key="McTimelineForegroundBrush"
					 Color="{StaticResource McTimelineForegroundColor}" />
	<SolidColorBrush x:Key="McTimelineGridLineBrush"
					 Color="{StaticResource McTimelineGridLineColor}" />
	<SolidColorBrush x:Key="McTimelineLegendBackgroundBrush"
					 Color="{StaticResource McTimelineLegendBackgroundColor}" />
	<SolidColorBrush x:Key="McTimelineMinimapBackgroundBrush"
					 Color="{StaticResource McTimelineMinimapBackgroundColor}" />
	<SolidColorBrush x:Key="McTimelineHoverBrush"
					 Color="{StaticResource McTimelineHoverColor}" />
	<SolidColorBrush x:Key="McTimelineSelectionBrush"
					 Color="{StaticResource McTimelineSelectionColor}" />

</ResourceDictionary>
