<UserControl
    x:Class="McTimelineDemo.Controls.ConfigurationPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:McTimelineDemo.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

  <!-- Configuration panel -->
  <Border x:Name="ConfigPanelContainer"
          Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
          MinWidth="200">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

      <StackPanel x:Name="ConfigPanel"
                  Padding="20"
                  Spacing="20"
                  HorizontalAlignment="Center">

        <Button Content="Change theme"
                Click="ThemeButton_Click" />

        <Button Content="Add new series"
                Command="{x:Bind AddNewSeries, Mode=OneWay}" />

        <CheckBox IsChecked="{x:Bind IsLegendVisible, Mode=TwoWay}"
                  Content="Show legend" />

        <NumberBox Header="Legend width"
                   SpinButtonPlacementMode="Inline"
                   Minimum="100"
                   Maximum="300"
                   SmallChange="10"
                   Value="{x:Bind LegendWidth, Mode=TwoWay}" />

        <NumberBox Header="Series height"
                   SpinButtonPlacementMode="Inline"
                   Minimum="30"
                   Maximum="300"
                   SmallChange="10"
                   Value="{x:Bind SeriesHeight, Mode=TwoWay}" />

        <NumberBox Header="Scale height"
                   SpinButtonPlacementMode="Inline"
                   Minimum="50"
                   Maximum="200"
                   SmallChange="10"
                   Value="{x:Bind ScaleHeight, Mode=TwoWay}" />

        <Button Content="Zoom series to fit"
                Click="ZoomSeriesToFit_Click" />

        <TextBlock Text="Styling" />

        <Button Content="Multicolor"
                Click="MulticolorButton_Click" />

        <Button Content="Gradients"
                Click="GradientsButton_Click" />

      </StackPanel>

    </ScrollViewer>

  </Border>
  
</UserControl>
