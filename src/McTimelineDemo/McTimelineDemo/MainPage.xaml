<Page x:Class="McTimelineDemo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:McTimelineDemo"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mctl="using:McTimeline"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="MyLegendStyle"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="{ThemeResource McTimelineGridLineBrush}" />
            <Setter Property="BorderThickness"
                    Value="0,0,1,0" />
            <Setter Property="Background"
                    Value="DarkSlateGray" />
        </Style>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds"
          ColumnDefinitions="Auto,*"
          RowSpacing="10">

        <StackPanel Padding="20"
                    Grid.Column="0"
                    Spacing="20"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Change theme"
                    Click="ThemeButton_Click" />

            <CheckBox x:Name="legendCheckBox"
                      IsChecked="True"
                      Content="Show legend" />

            <Button Content="New collection"
                    Command="{x:Bind ViewModel.GenerarNovaCollecioCommand}" />

            <ListBox Height="150"
                     SelectedIndex="0"
                     ItemsSource="{x:Bind ViewModel.Series, Mode=OneWay}"
                     Foreground="{ThemeResource McTimelineAccentBrush}" />

        </StackPanel>

        <mctl:McTimeline Grid.Column="1"
                         SeriesCollection="{x:Bind ViewModel.Series, Mode=OneWay}"
                         LegendCaption="Timeline Graph"
                         LegendCaptionStyle="{StaticResource DefaultLegendCaptionStyle}"
                         IsLegendVisible="{Binding IsChecked, ElementName=legendCheckBox}"
                         Margin="30" />
    </Grid>

</Page>
