<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:local="using:McTimeline"
					xmlns:controls="using:McTimeline.Controls">

	<!-- Merge all resource dictionaries -->
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="ms-appx:///McTimeline/Themes/McTimelineResources.xaml" />
	</ResourceDictionary.MergedDictionaries>

	<!-- McTimeline Template -->
	<Style TargetType="local:McTimeline">
		<Setter Property="Background"
				Value="{ThemeResource McTimelineBackgroundBrush}" />
		<Setter Property="Foreground"
				Value="{ThemeResource McTimelineForegroundBrush}" />
		<Setter Property="TimeScaleStyle"
				Value="{StaticResource DefaultTimeScaleStyle}" />
		<Setter Property="LegendStyle"
				Value="{StaticResource DefaultLegendStyle}" />
		<Setter Property="LegendCaptionStyle"
				Value="{StaticResource DefaultLegendCaptionStyle}" />
		<Setter Property="LegendItemStyle"
				Value="{StaticResource DefaultLegendItemStyle}" />
		<Setter Property="TimelineScrollStyle"
				Value="{StaticResource DefaultTimelineScrollStyle}" />
		<Setter Property="TimelineCanvasStyle"
				Value="{StaticResource DefaultTimelineCanvasStyle}" />
		<Setter Property="TimelineItemStyle"
				Value="{StaticResource DefaultTimelineItemStyle}" />
		<Setter Property="LegendItemTemplate"
				Value="{StaticResource DefaultLegendItemTemplate}" />
		<Setter Property="BorderBrush"
				Value="{ThemeResource McTimelineBorderBrush}" />
		<Setter Property="BorderThickness"
				Value="{ThemeResource McTimelineBorderThickness}" />
		<Setter Property="CornerRadius"
				Value="{ThemeResource McTimelineCornerRadius}" />
		<Setter Property="ScaleHeight"
				Value="{ThemeResource McTimelineDefaultTimeScaleHeight}" />
		<Setter Property="LegendWidth"
				Value="{ThemeResource McTimelineDefaultLegendWidth}" />

		<Setter Property="Template">

			<Setter.Value>

				<ControlTemplate TargetType="local:McTimeline">

					<Grid x:Name="PART_Container"
						  Height="{TemplateBinding Height}"
						  Width="{TemplateBinding Width}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Background="{TemplateBinding Background}">

						<Grid.RowDefinitions>
							<!-- legend caption / time scale -->
							<RowDefinition Height="{TemplateBinding ScaleHeight}" />
							<!-- legend items / timeline / vertical scrollbar -->
							<RowDefinition Height="*" />
							<!-- horizontal scrollbar -->
							<RowDefinition Height="auto" />
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<!-- caption and legend -->
							<ColumnDefinition Width="{TemplateBinding LegendWidth}" />
							<!-- timeline scale and bars -->
							<ColumnDefinition Width="*" />
							<!-- vertical scrollbar -->
							<ColumnDefinition Width="auto" />
						</Grid.ColumnDefinitions>

						<!-- legend caption -->
						<Border Grid.Row="0"
								Grid.Column="0"
								BorderBrush="{ThemeResource McTimelineGridLineBrush}"
								BorderThickness="0,0,1,1">

							<TextBlock x:Name="PART_LegendCaption"
									   Text="{TemplateBinding LegendCaption}"
									   Style="{TemplateBinding LegendCaptionStyle}" />

						</Border>

						<!-- Time Scale -->
						<Grid x:Name="PART_TimeScaleGrid"
							  Grid.Row="0"
							  Grid.Column="1">
							<Grid.RowDefinitions>
								<!-- Dates / Days -->
								<RowDefinition Height="*" />
								<!-- Hours -->
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>
							
							<!--Border overlay for both rows-->
							<Border BorderBrush="{ThemeResource McTimelineGridLineBrush}"
									Style="{TemplateBinding TimeScaleStyle}"
									BorderThickness="0,0,0,1"
									Grid.RowSpan="2" />

							<!-- Time Scale Days -->
							<Canvas x:Name="PART_TimeScaleDays"
									Grid.Row="0" />

							<!-- Time Scale Hours -->
							<Canvas x:Name="PART_TimeScaleHours"
									Grid.Row="1" />
						</Grid>

						<!--Blank-->
						<Border Grid.Row="0"
								Grid.Column="2"
								Style="{TemplateBinding TimeScaleStyle}"
								BorderBrush="{ThemeResource McTimelineGridLineBrush}"
								BorderThickness="0,0,0,1" />

						<!-- Legend -->
						<Border x:Name="PART_LegendBorder"
								Grid.Row="1"
								Grid.Column="0"
								BorderBrush="{ThemeResource McTimelineGridLineBrush}"
							    BorderThickness="0,0,1,0">

						<Canvas x:Name="PART_LegendCanvas"
								Style="{TemplateBinding LegendStyle}" />
					</Border>

					<!-- Timeline Canvas -->
				    <Canvas x:Name="PART_TimelineCanvas"
							Grid.Row="1"
							Grid.Column="1"
							Style="{TemplateBinding TimelineCanvasStyle}" />

					<!-- Vertical ScrollBar -->
					<ScrollBar x:Name="PART_VScroll"
							   Grid.Row="1"
							   Grid.Column="2"
							   IndicatorMode="MouseIndicator" />

						<!--Blank column below legend, share same style -->
						<Border Grid.Row="2"
								Grid.Column="0"
								Style="{TemplateBinding LegendStyle}"
								BorderBrush="{ThemeResource McTimelineGridLineBrush}"
								BorderThickness="0,0,1,0" />

						<!-- Horizontal ScrollBar -->
						<ScrollBar x:Name="PART_HScroll"
								   Grid.Row="2"
								   Grid.Column="1"
								   Orientation="Horizontal"
								   Minimum="0"
								   Maximum="0"
								   VerticalAlignment="Stretch"
								   IndicatorMode="MouseIndicator" />

					</Grid>

				</ControlTemplate>

			</Setter.Value>

		</Setter>

	</Style>

	<!-- McLegend Template -->
	<Style TargetType="controls:McLegend">
		<Setter Property="Background" Value="{ThemeResource McTimelineLegendBackgroundBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource McTimelineBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource McTimelineBorderThickness}" />
		<Setter Property="Padding" Value="{ThemeResource McTimelineDefaultPadding}" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{ThemeResource McTimelineForegroundBrush}" />

		<Setter Property="Template">

			<Setter.Value>

				<ControlTemplate TargetType="controls:McLegend">

					<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="{TemplateBinding CornerRadius}"
						Padding="{TemplateBinding Padding}">

						<TextBlock
							HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
							Text="{TemplateBinding LegendText}"
							TextAlignment="Center"
							VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
							Foreground="{TemplateBinding Foreground}" />

					</Border>

				</ControlTemplate>

			</Setter.Value>

		</Setter>
		
	</Style>

	<!-- McTimelineBar Template -->
	<Style TargetType="controls:McTimelineBar">
		<Setter Property="Background" Value="{ThemeResource McTimelineItemBackgroundBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource McTimelineBorderBrush}" />
		<Setter Property="BorderThickness" Value="{StaticResource McTimelineBorderThickness}" />
		<Setter Property="Padding" Value="{StaticResource McTimelineDefaultPadding}" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Foreground" Value="{ThemeResource McTimelineForegroundBrush}" />

		<Setter Property="Template">

			<Setter.Value>

				<ControlTemplate TargetType="controls:McTimelineBar">

					<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="{TemplateBinding CornerRadius}"
						Padding="{TemplateBinding Padding}"
						ToolTipService.ToolTip="{TemplateBinding ItemToolTip}"
						Margin="0,5,0,5">

						<TextBlock
							HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
							Text="{TemplateBinding ItemText}"
							TextAlignment="Center"
							VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
							Foreground="{TemplateBinding Foreground}" />

					</Border>

				</ControlTemplate>

			</Setter.Value>

		</Setter>
		
	</Style>

</ResourceDictionary>
