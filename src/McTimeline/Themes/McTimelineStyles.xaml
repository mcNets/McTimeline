<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:McTimeline">

        <!-- Default Styles for control parts -->

        <!-- Default style for time scale grid -->
        <Style x:Key="DefaultTimeScaleStyle"
               TargetType="Grid">
                <Setter Property="BorderBrush"
                        Value="{ThemeResource McTimelineGridLineBrush}"/>
                <Setter Property="BorderThickness"
                        Value="0,0,0,1"/>
        </Style>

        <!-- Default style for legend border -->
        <Style x:Key="DefaultLegendStyle"
               TargetType="Border">
                <Setter Property="BorderBrush"
                        Value="{ThemeResource McTimelineGridLineBrush}"/>
                <Setter Property="BorderThickness"
                        Value="0,0,1,0"/>
                <Setter Property="Background"
                        Value="{ThemeResource McTimelineLegendBackgroundBrush}"/>
        </Style>


        <!-- LEGEND -->


        <!-- Default style for legend caption -->
        <Style x:Key="DefaultLegendCaptionStyle"
               TargetType="TextBlock">
                <Setter Property="VerticalAlignment"
                        Value="Center"/>
                <Setter Property="HorizontalAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{ThemeResource McTimelineAccentBrush}"/>
                <Setter Property="FontFamily"
                        Value="{ThemeResource McTimelineFontFamily}"/>
                <Setter Property="FontSize"
                        Value="{ThemeResource McTimelineLargeFontSize}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="TextTrimming"
                        Value="CharacterEllipsis"/>
                <Setter Property="Padding"
                        Value="3"/>
        </Style>

        <!-- Default style for each legend item -->
        <Style x:Key="DefaultLegendItemStyle"
               TargetType="Border">
                <Setter Property="Height"
                        Value="{ThemeResource McTimelineDefaultRowHeight}"/>
                <Setter Property="Padding"
                        Value="{ThemeResource McTimelineDefaultPadding}"/>
                <Setter Property="BorderBrush"
                        Value="{ThemeResource McTimelineGridLineBrush}"/>
                <Setter Property="BorderThickness"
                        Value="0,0,0,1"/>
        </Style>

        <Style x:Key="DefaultLegendItemTextStyle"
               TargetType="TextBlock">
                <Setter Property="VerticalAlignment"
                        Value="Center"/>
                <Setter Property="Foreground"
                        Value="{ThemeResource McTimelineForegroundBrush}"/>
                <Setter Property="FontFamily"
                        Value="{ThemeResource McTimelineFontFamily}"/>
                <Setter Property="FontSize"
                        Value="{ThemeResource McTimelineFontSize}"/>
                <Setter Property="FontWeight"
                        Value="SemiBold"/>
                <Setter Property="TextTrimming"
                        Value="CharacterEllipsis"/>
        </Style>

        <!-- Default style for ScrollViewer -->
        <Style x:Key="DefaultTimelineScrollStyle"
               TargetType="ScrollViewer">
                <Setter Property="HorizontalScrollBarVisibility"
                        Value="Visible"/>
                <Setter Property="VerticalScrollBarVisibility"
                        Value="Auto"/>
                <Setter Property="HorizontalScrollMode"
                        Value="Enabled"/>
                <Setter Property="VerticalScrollMode"
                        Value="Auto"/>
        </Style>

        <!-- Default style for Canvas -->
        <Style x:Key="DefaultTimelineCanvasStyle"
               TargetType="Canvas">
                <Setter Property="Background"
                        Value="Transparent"/>
        </Style>

        <!-- Default DataTemplate for legend items -->
        <DataTemplate x:Key="DefaultLegendItemTemplate">
                <Border Style="{StaticResource DefaultLegendItemStyle}">
                        <TextBlock Text="{Binding Title, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource McTimelineForegroundBrush}"
                                   FontFamily="{ThemeResource McTimelineFontFamily}"
                                   FontSize="{ThemeResource McTimelineFontSize}"
                                   FontWeight="SemiBold"/>
                </Border>
        </DataTemplate>

</ResourceDictionary>