<Page x:Class="McTimelineDemo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:McTimelineDemo"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mctl="using:McTimeline"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="MyLegendStyle"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="{ThemeResource McTimelineGridLineBrush}" />
            <Setter Property="BorderThickness"
                    Value="0,0,1,0" />
            <Setter Property="Background"
                    Value="DarkSlateGray" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid utu:SafeArea.Insets="VisibleBounds"
              Margin="40, 100">
            <mctl:McTimeline RequestedTheme="Light" />
        </Grid>

        <Button VerticalAlignment="Top" Content="Theme"
                Click="Button_Click" />

    </Grid>

</Page>
