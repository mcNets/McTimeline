<Page x:Class="McTimelineDemo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:McTimelineDemo"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mctl="using:McTimeline"
      xmlns:mctlc="using:McTimeline.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Page.Resources>
                <Style x:Key="MyLegendStyle"
                       TargetType="mctlc:McLegend">
                        <Setter Property="BorderBrush"
                                Value="Red"/>
                        <Setter Property="BorderThickness"
                                Value="0,0,0,1"/>
                </Style>
        </Page.Resources>

        <Grid utu:SafeArea.Insets="VisibleBounds"
              RowSpacing="10">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ConfigColumn"
                                          Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Configuration panel -->
                <Border x:Name="ConfigPanelContainer"
                        Grid.Column="0"
                        Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                        Margin="10"
                        MinWidth="200">

                        <ScrollViewer VerticalScrollBarVisibility="Auto">

                                <StackPanel x:Name="ConfigPanel"
                                            Padding="20"
                                            Spacing="20"
                                            HorizontalAlignment="Center">

                                        <Button Content="Change theme"
                                                Click="ThemeButton_Click"/>

                                        <Button Content="Add new series"
                                                Command="{x:Bind ViewModel.AddNewSeriesCommand}"/>

                                        <CheckBox IsChecked="{x:Bind ViewModel.IsLegendVisible, Mode=TwoWay}"
                                                  Content="Show legend"/>

                                        <NumberBox Header="Legend width"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="100"
                                                   Maximum="300"
                                                   SmallChange="10"
                                                   Value="{x:Bind ViewModel.LegendWidth, Mode=TwoWay}"/>

                                        <NumberBox Header="Series height"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="30"
                                                   Maximum="300"
                                                   SmallChange="10"
                                                   Value="{Binding ElementName=TimelineControl, Path=SeriesHeight, Mode=TwoWay}"/>

                                        <NumberBox Header="Scale height"
                                                   SpinButtonPlacementMode="Inline"
                                                   Minimum="50"
                                                   Maximum="200"
                                                   SmallChange="10"
                                                   Value="{x:Bind ViewModel.ScaleHeight, Mode=TwoWay}"/>

                                        <Button Content="Zoom series to fit"
                                                Click="ZoomSeriesToFitButton_Click"/>

                                </StackPanel>

                        </ScrollViewer>

                </Border>

                <!-- Config panel toggle button -->
                <Button x:Name="ConfigToggleButton"
                        Grid.Column="1"
                        Width="32"
                        Height="32"
                        Margin="0,10,10,0"
                        VerticalAlignment="Top"
                        Background="{ThemeResource AccentAcrylicBackgroundFillColorBaseBrush}"
                        Content="⟪"
                        Click="ConfigToggleButton_Click"/>

                <!-- Timeline control -->
                <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical"
                                    Grid.Row="0"
                                    Spacing="10"
                                    Margin="30,10">
                                <TextBlock>
<Run Text="Horizontal scroll: "/>
<Run Text="Mouse wheel"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </TextBlock>
                                <TextBlock>
<Run Text="Vertical scroll: "/>
<Run Text="Mouse wheel + Shift"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </TextBlock>
                                <TextBlock>
<Run Text="Zoom in/out: "/>
<Run Text="Ctrl + Mouse wheel"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                </TextBlock>
                        </StackPanel>

                        <mctl:McTimeline Grid.Row="1"
                                         x:Name="TimelineControl"
                                         LegendWidth="{x:Bind ViewModel.LegendWidth, Mode=OneWay}"
                                         ScaleHeight="{x:Bind ViewModel.ScaleHeight, Mode=OneWay}"
                                         SeriesCollection="{x:Bind ViewModel.Series, Mode=OneWay}"
                                         SeriesHeight="{x:Bind ViewModel.SeriesHeight, Mode=OneWay}"
                                         LegendCaption="Timeline Graph"
                                         LegendCaptionStyle="{StaticResource DefaultLegendCaptionStyle}"
                                         IsLegendVisible="{x:Bind ViewModel.IsLegendVisible, Mode=OneWay}"
                                         MinDate="{x:Bind ViewModel.DataInici, Mode=OneWay}"
                                         MaxDate="{x:Bind ViewModel.DataFinal, Mode=OneWay}"
                                         Margin="30"/>
                </Grid>
        </Grid>

</Page>
