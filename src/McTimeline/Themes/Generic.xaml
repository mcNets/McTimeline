<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:McTimeline"
                    xmlns:controls="using:McTimeline.Controls">

  <!-- Merge all resource dictionaries -->
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="ms-appx:///McTimeline/Themes/McTimelineResources.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <!-- McTimeline Template -->
  <Style TargetType="local:McTimeline">
    <Setter Property="Foreground"
            Value="{ThemeResource McTimelineForegroundBrush}" />
    <Setter Property="ScaleHeight"
            Value="{ThemeResource McTimelineDefaultTimeScaleHeight}" />
    <Setter Property="PixelsPerHour"
            Value="{ThemeResource McTimelineDefaultPixelsPerHour}" />
    <Setter Property="LegendWidth"
            Value="{ThemeResource McTimelineDefaultLegendWidth}" />
    <Setter Property="IsTextVisible"
            Value="true" />
    <Setter Property="IsLegendVisible"
            Value="true" />

    <Setter Property="TimelineStyle"
            Value="{ThemeResource DefaultTimelineStyle}" />

    <Setter Property="TimeScaleStyle"
            Value="{ThemeResource DefaultTimeScaleStyle}" />
    <Setter Property="TimeScaleDaysStyle"
            Value="{ThemeResource DefaultTimeScaleDaysStyle}" />
    <Setter Property="TimeScaleHoursStyle"
            Value="{ThemeResource DefaultTimeScaleHoursStyle}" />
    <Setter Property="TimeScaleTickStyle"
            Value="{ThemeResource DefaultTimeScaleTickStyle}" />
    <Setter Property="LegendStyle"
            Value="{ThemeResource DefaultLegendStyle}" />
    <Setter Property="LegendCaptionStyle"
            Value="{ThemeResource DefaultLegendCaptionStyle}" />
    <Setter Property="LegendItemStyle"
            Value="{ThemeResource DefaultLegendItemStyle}" />
    <Setter Property="TimelineScrollStyle"
            Value="{ThemeResource DefaultTimelineScrollStyle}" />
    <Setter Property="TimelineCanvasStyle"
            Value="{StaticResource DefaultTimelineCanvasStyle}" />
    <Setter Property="TimelineItemStyle"
            Value="{StaticResource DefaultTimelineItemStyle}" />
    <Setter Property="LegendItemTemplate"
            Value="{StaticResource DefaultLegendItemTemplate}" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="local:McTimeline">

          <!-- Container -->
          <Border Style="{TemplateBinding TimelineStyle}" >
  
            <Grid x:Name="PART_Container"
                  Height="{TemplateBinding Height}"
                  Width="{TemplateBinding Width}">
  
              <Grid.RowDefinitions>
                <!-- legend caption / time scale -->
                <RowDefinition Height="{TemplateBinding ScaleHeight}" />
                <!-- legend items / timeline / vertical scrollbar -->
                <RowDefinition Height="*" />
                <!-- horizontal scrollbar -->
                <RowDefinition Height="auto" />
              </Grid.RowDefinitions>
  
              <Grid.ColumnDefinitions>
                <!-- caption and legend -->
                <ColumnDefinition Width="{TemplateBinding LegendWidth}" />
                <!-- timeline scale and bars -->
                <ColumnDefinition Width="*" />
                <!-- vertical scrollbar -->
                <ColumnDefinition Width="auto" />
              </Grid.ColumnDefinitions>
  
              <!-- legend caption -->
              <Border Grid.Row="0"
                      Grid.Column="0"
                      BorderBrush="{ThemeResource McTimelineGridLineBrush}"
                      BorderThickness="{StaticResource McTimelineBorderBottomRightThickness}">
  
                <TextBlock x:Name="PART_LegendCaption"
                           Text="{TemplateBinding LegendCaption}"
                           Style="{TemplateBinding LegendCaptionStyle}" />
  
              </Border>
  
              <!--Timeline scale container-->
              <Border Style="{TemplateBinding TimeScaleStyle}"
                      Grid.Row="0"
                      Grid.Column="1" >
  
                <Grid x:Name="PART_TimeScaleGrid">
                  <Grid.RowDefinitions>
                    <!-- Days -->
                    <RowDefinition Height="*" />
                    <!-- Hours -->
                    <RowDefinition Height="*" />
                  </Grid.RowDefinitions>
    
                  <!-- Time Scale Days -->
                  <Canvas x:Name="PART_TimeScaleDays"
                          Grid.Row="0" />
    
                  <!-- Time Scale Hours -->
                  <Canvas x:Name="PART_TimeScaleHours"
                          Grid.Row="1" />
              
                </Grid>

              </Border>
  
              <!--Blank-->
              <!-- <Border Grid.Row="0"
                      Grid.Column="2"
                      Style="{TemplateBinding TimeScaleStyle}"
                      BorderBrush="{ThemeResource McTimelineGridLineBrush}"
                      BorderThickness="{StaticResource McTimelineBorderBottomThickness}" /> -->
  
              <!-- Legend -->
              <Border x:Name="PART_LegendBorder"
                      Grid.Row="1"
                      Grid.Column="0"
                      BorderBrush="{ThemeResource McTimelineGridLineBrush}"
                      BorderThickness="{StaticResource McTimelineBorderRightThickness}">
  
                <Canvas x:Name="PART_LegendCanvas"
                        Style="{TemplateBinding LegendStyle}" />
              </Border>
  
              <!-- Timeline Canvas -->
              <Canvas x:Name="PART_TimelineCanvas"
                      Grid.Row="1"
                      Grid.Column="1"
                      Style="{TemplateBinding TimelineCanvasStyle}" />
  
              <!-- Vertical ScrollBar -->
              <ScrollBar x:Name="PART_VScroll"
                         Grid.Row="1"
                         Grid.Column="2"
                         IndicatorMode="MouseIndicator" />
  
              <!--Blank column below legend, share same style -->
              <Border Grid.Row="2"
                      Grid.Column="0"
                      Style="{TemplateBinding LegendStyle}"
                      BorderBrush="{ThemeResource McTimelineGridLineBrush}"
                      BorderThickness="0,0,1,0" />
  
              <!-- Horizontal ScrollBar -->
              <ScrollBar x:Name="PART_HScroll"
                         Grid.Row="2"
                         Grid.Column="1"
                         Orientation="Horizontal"
                         Minimum="0"
                         Maximum="0"
                         VerticalAlignment="Stretch"
                         IndicatorMode="MouseIndicator" />
  
            </Grid>
  
          </Border>

        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- McLegend Template -->
  <Style TargetType="controls:McLegend">
    <Setter Property="Background"
            Value="{ThemeResource McTimelineLegendBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{ThemeResource McTimelineBorderBrush}" />
    <Setter Property="BorderThickness"
            Value="0" />
    <Setter Property="Padding"
            Value="{ThemeResource McTimelineDefaultPadding}" />
    <Setter Property="HorizontalContentAlignment"
            Value="Center" />
    <Setter Property="VerticalContentAlignment"
            Value="Center" />
    <Setter Property="Foreground"
            Value="{ThemeResource McTimelineForegroundBrush}" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:McLegend">

          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">

            <TextBlock HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                       Text="{TemplateBinding LegendText}"
                       TextAlignment="Center"
                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                       Foreground="{TemplateBinding Foreground}" />

          </Border>

        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- McTimelineBar Template -->
  <Style TargetType="controls:McTimelineBar">
    <Setter Property="Background"
            Value="{ThemeResource McTimelineItemBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{ThemeResource McTimelineBorderBrush}" />
    <Setter Property="BorderThickness"
            Value="{StaticResource McTimelineBorderThickness}" />
    <Setter Property="Padding"
            Value="{StaticResource McTimelineDefaultPadding}" />
    <Setter Property="HorizontalContentAlignment"
            Value="Center" />
    <Setter Property="VerticalContentAlignment"
            Value="Center" />
    <Setter Property="Foreground"
            Value="{ThemeResource McTimelineForegroundBrush}" />
    <Setter Property="Margin"
            Value="0,5,0,5" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:McTimelineBar">

          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}"
                  ToolTipService.ToolTip="{TemplateBinding ItemToolTip}"
                  Margin="{TemplateBinding Margin}">

            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="TextVisibilityStates">
                <VisualState x:Name="TextVisible" />
                <VisualState x:Name="TextHidden">
                  <VisualState.Setters>
                    <Setter Target="PART_ItemText.Visibility" Value="Collapsed" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <TextBlock x:Name="PART_ItemText"
                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                       Text="{TemplateBinding ItemText}"
                       TextAlignment="Center"
                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                       Foreground="{TemplateBinding Foreground}" />

          </Border>

        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
