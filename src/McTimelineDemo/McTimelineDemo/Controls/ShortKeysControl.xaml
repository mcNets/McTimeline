<UserControl
    x:Class="McTimelineDemo.Controls.ShortKeysControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Zoom and scroll instructions -->
    <Grid ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Padding="8"
                CornerRadius="6"
                Grid.Column="0"
                Background="{ThemeResource ControlFillColorSecondaryBrush}">

            <TextBlock>
                <Run Text="Horizontal scroll: "
                     FontWeight="Bold"/>
                <Run Text="Mouse wheel"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </TextBlock>

        </Border>


        <Border Padding="8"
                CornerRadius="6"
                Grid.Column="1"
                Background="{ThemeResource ControlFillColorSecondaryBrush}">

            <TextBlock>
                <Run Text="Vertical scroll: "
                     FontWeight="Bold"/>
                <Run Text="Shift + Mouse wheel"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </TextBlock>

        </Border>

        <Border Padding="8"
                CornerRadius="6"
                Grid.Column="2"
                Background="{ThemeResource ControlFillColorSecondaryBrush}">

            <TextBlock>
                <Run Text="Zoom in/out: "
                     FontWeight="Bold"/>
                <Run Text="Ctrl + Mouse wheel"
                     Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </TextBlock>

        </Border>

    </Grid>

</UserControl>