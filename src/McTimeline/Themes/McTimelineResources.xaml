<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Merge Styles -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///McTimeline/Themes/McTimelineStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Theme-aware dictionaries -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light"
                            Source="ms-appx:///McTimeline/Themes/ThemeResources.Light.xaml" />

        <ResourceDictionary x:Key="Dark"
                            Source="ms-appx:///McTimeline/Themes/ThemeResources.Dark.xaml" />
    </ResourceDictionary.ThemeDictionaries>

    <!-- Dimensions -->
    <x:Double x:Key="McTimelineDefaultRowHeight">40</x:Double>
    <x:Double x:Key="McTimelineDefaultSeriesLabelWidth">200</x:Double>
    <x:Double x:Key="McTimelineDefaultPixelsPerHour">60</x:Double>
    <x:Double x:Key="McTimelineMinPixelsPerHour">5</x:Double>
    <x:Double x:Key="McTimelineMaxPixelsPerHour">300</x:Double>
    <x:Double x:Key="McTimelineTimeScaleHeight">50</x:Double>
    <x:Double x:Key="McTimelineMinimapHeight">80</x:Double>

    <!-- Thickness -->
    <Thickness x:Key="McTimelineDefaultPadding">8</Thickness>
    <Thickness x:Key="McTimelineItemPadding">4,2</Thickness>
    <Thickness x:Key="McTimelineBorderThickness">1</Thickness>

    <CornerRadius x:Key="McTimelineCornerRadius">8</CornerRadius>

    <!-- Fonts -->
    <FontFamily x:Key="McTimelineFontFamily">Segoe UI</FontFamily>
    <x:Double x:Key="McTimelineFontSize">14</x:Double>
    <x:Double x:Key="McTimelineSmallFontSize">12</x:Double>
    <x:Double x:Key="McTimelineLargeFontSize">16</x:Double>

</ResourceDictionary>
